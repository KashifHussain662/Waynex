{
  "expo": {
    "name": "Waynex",
    "slug": "waynex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "waynex",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#FFFFFF",
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.kashifhussain662.waynex"
    },
    "extra": {
      "eas": {
        "projectId": "b4a0672e-bbbe-4600-beda-d9456cff788c"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Waynex uses your location to share live journeys with people you choose.",
          "locationWhenInUsePermission": "Waynex uses your location for route intelligence and nearby travel safety.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-notifications",
      "expo-task-manager"
    ]
  }
}
