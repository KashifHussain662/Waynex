rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isPublic() {
      return resource.data.visibility == "public";
    }

    function incomingPublic() {
      return request.resource.data.visibility == "public";
    }

    function tripMember(tripId) {
      return signedIn()
        && exists(/databases/$(database)/documents/tripMembers/$(tripId + "_" + request.auth.uid));
    }

    function chatParticipant(roomId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chatRooms/$(roomId))
        && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds;
    }

    function canReadPrivateUserContent(userId) {
      return isOwner(userId);
    }

    match /users/{userId} {
      allow read: if signedIn() && (resource.data.privacy.profileVisibility == "public" || isOwner(userId));
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;

      match /followers/{followerId} {
        allow read: if signedIn();
        allow create, delete: if isOwner(followerId);
        allow update: if false;
      }

      match /following/{followingId} {
        allow read: if signedIn();
        allow create, delete: if isOwner(userId);
        allow update: if false;
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isOwner(userId);
      }

      match /savedPosts/{savedPostId} {
        allow read, create, delete: if isOwner(userId);
        allow update: if false;
      }

      match /savedPlaces/{savedPlaceId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /memories/{memoryId} {
        allow read: if isOwner(userId) || resource.data.visibility == "public";
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /posts/{postId} {
      allow read: if isPublic()
        || isOwner(resource.data.authorId)
        || (resource.data.visibility == "trip-members" && tripMember(resource.data.tripId));
      allow create: if isOwner(request.resource.data.authorId)
        && request.resource.data.visibility in ["public", "private", "friends", "trip-members"];
      allow update: if isOwner(resource.data.authorId)
        || (signedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "likesCount",
            "commentsCount",
            "sharesCount",
            "savedCount",
            "updatedAt"
          ]));
      allow delete: if isOwner(resource.data.authorId);

      match /comments/{commentId} {
        allow read: if get(/databases/$(database)/documents/posts/$(postId)).data.visibility == "public"
          || isOwner(get(/databases/$(database)/documents/posts/$(postId)).data.authorId);
        allow create: if isOwner(request.resource.data.authorId);
        allow update, delete: if isOwner(resource.data.authorId);
      }

      match /likes/{likeId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && likeId == request.auth.uid
          && request.resource.data.userId == request.auth.uid;
        allow delete: if signedIn() && likeId == request.auth.uid;
        allow update: if false;
      }
    }

    match /comments/{commentId} {
      allow read: if resource.data.visibility == "public" || isOwner(resource.data.authorId);
      allow create: if isOwner(request.resource.data.authorId);
      allow update, delete: if isOwner(resource.data.authorId);
    }

    match /stories/{storyId} {
      allow read: if resource.data.visibility == "public" || isOwner(resource.data.authorId);
      allow create: if isOwner(request.resource.data.authorId);
      allow update, delete: if isOwner(resource.data.authorId);
    }

    match /chatRooms/{roomId} {
      allow read, update: if chatParticipant(roomId);
      allow create: if signedIn() && request.auth.uid in request.resource.data.participantIds;
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;

      match /messages/{messageId} {
        allow read: if chatParticipant(roomId);
        allow create: if chatParticipant(roomId) && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if resource.data.senderId == request.auth.uid;
      }
    }

    match /messages/{messageId} {
      allow read: if chatParticipant(resource.data.chatRoomId);
      allow create: if chatParticipant(request.resource.data.chatRoomId)
        && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if resource.data.senderId == request.auth.uid;
    }

    match /trips/{tripId} {
      allow read: if resource.data.visibility == "public" || tripMember(tripId) || isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
      allow update, delete: if isOwner(resource.data.ownerId) || tripMember(tripId);

      match /members/{memberId} {
        allow read: if tripMember(tripId);
        allow create, update: if signedIn() && (request.resource.data.userId == request.auth.uid || tripMember(tripId));
        allow delete: if signedIn() && (resource.data.userId == request.auth.uid || tripMember(tripId));
      }
    }

    match /tripMembers/{memberId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || tripMember(resource.data.tripId));
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /followers/{followId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if signedIn() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    match /following/{followId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if signedIn() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    match /savedPosts/{savedPostId} {
      allow read, delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /savedPlaces/{savedPlaceId} {
      allow read, delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if signedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /memories/{memoryId} {
      allow read: if resource.data.visibility == "public" || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /reports/{reportId} {
      allow read: if signedIn();
      allow create: if isOwner(request.resource.data.reporterId);
      allow update, delete: if false;
    }

    match /hotels/{hotelId} {
      allow read: if true;
      allow write: if false;
    }

    match /places/{placeId} {
      allow read: if true;
      allow write: if false;
    }

    match /roadReports/{roadReportId} {
      allow read: if resource.data.status == "active";
      allow create: if isOwner(request.resource.data.authorId);
      allow update, delete: if isOwner(resource.data.authorId);
    }

    match /weatherCache/{weatherId} {
      allow read: if true;
      allow write: if false;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
